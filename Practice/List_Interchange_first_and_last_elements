#Interchange_first_and_last_elements

Input: 
lst = [1, 2, 3, 4, 5]

--------------------------------------
#Using a temp variable

tmp = lst[0]
lst[0] = lst[-1]
lst[-1] = tmp
print(lst)

--------------------------------------
#Using Direct Assignment

lst[0], lst[-1] = lst[-1], lst[0]
print( lst)

----------------------------------------
#Using the * Operator

a, *b, c = lst
lst = c, *b, a

print(lst)
