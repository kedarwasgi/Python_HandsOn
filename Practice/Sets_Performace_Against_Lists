#Sets_Performace_Against_Lists

'''
Sets use a hash table internally. The in operator computes hash(element) to find the bucket — O(1)
average. Elements MUST be hashable (immutable types). Lists, dicts, and sets cannot be set elements.
'''

# Membership test: O(1) for set, O(n) for list
big_set = set(range(1_000_000))
big_list = list(range(1_000_000))

# Both return True but set is dramatically faster
print(999_999 in big_set) # True — O(1)
print(999_999 in big_list) # True — O(n), much slower

# Only hashable types allowed as set elements
valid = {1, 'hello', (1,2), 3.14} # OK

try:
  invalid = {[1, 2]} # list is unhashable
except TypeError as e:
  print(e) # unhashable type: 'list
