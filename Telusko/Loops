
# Intro while loops

i = 1

while i < 5:
    print('Kedar', end = ' ')
    j = 1
    while j < 3:
        print('Rocks!', end = ' ')
        j += 1
    print("")
    i +=1

'''
Output:

Kedar Rocks! Rocks! 
Kedar Rocks! Rocks! 
Kedar Rocks! Rocks! 
Kedar Rocks! Rocks! 
'''
