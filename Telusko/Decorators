# Decorator is a function which takes another function as an argument and performs some trasformations/modifications/feature_enhancements and returns a function.
 
def decorators(func):
    def wrapper():
        print('Transaction Initiated.')
        func()
        print('Transaction Completed.')
    return wrapper


