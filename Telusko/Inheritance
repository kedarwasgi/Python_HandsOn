#Inheritance:

Inheritance is a feature that allows one class (child/derived class) to acquire the properties and methods of another class (parent/base class).
It promotes code reusability, extensibility, and maintainability.

eg.

class ott_subscription:   #Parent Class
    def __init__(self,id,plan,amount):
        self.id = id
        self.plan = plan
        self.amount = amount
    
    def subscribe(self):
        print(f'User with subscription id {self.id} has subscribed to {self.plan} plan')

    def unsubscribe(self):
        print(f'User with subscription id {self.id} has unsubscribed to {self.plan} plan') 

# s1 = ott_subscription(12345,'Monthly', 249)
# s1.subscribe()

class premium_ott_subscription(ott_subscription):  #Child Class
    def __init__(self,id,plan,amount,max_screens):
        super().__init__(id,plan,amount)
        self.max_screens =  max_screens
        
    def show_max_screens(self,screens):
        self.max_screens = screens
        print(f'The maximum screens allowed is {self.max_screens}')

s2 = premium_ott_subscription('223344','Quarterly',699,4)
s2.subscribe()
s2.show_max_screens(4)
